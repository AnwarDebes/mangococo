# ===========================================
# MEXC CREDENTIALS
# ===========================================
MEXC_API_KEY=your_mexc_api_key_here
MEXC_SECRET_KEY=your_mexc_secret_key_here

# ===========================================
# OPTIONAL DATA SOURCE KEYS (enable full features)
# ===========================================
CRYPTOPANIC_API_KEY=your_cryptopanic_api_key_here
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=goblin-sentiment/1.0
WHALE_ALERT_API_KEY=

# ===========================================
# INFRASTRUCTURE
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=goblin
POSTGRES_USER=goblin
POSTGRES_PASSWORD=change_me

# ===========================================
# TRADING MODE
# ===========================================
# Set to true for paper trading (no real orders), false for live trading
PAPER_MODE=true

# ===========================================
# TRADING PAIRS
# ===========================================
TRADING_PAIRS=BTC/USDT,ETH/USDT,SOL/USDT
TRADING_PAIRS_LIMIT=0

# ===========================================
# CAPITAL & RISK MANAGEMENT
# ===========================================
STARTING_CAPITAL=1000.0
MAX_POSITION_PCT=0.50
MIN_POSITION_USD=1.0
MAX_DAILY_LOSS_PCT=0.20
MAX_OPEN_POSITIONS=2
MIN_TIME_BETWEEN_TRADES=60
PROFIT_TARGET_PCT=0.002
MAX_TRADE_LOSS_PCT=0.005
MAX_HOLD_TIME_MINUTES=30

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
DB_ENABLED=true
WS_ENABLED=true
WS_TOP_SYMBOLS=100
REST_POLL_INTERVAL=1.0
FEATURE_COMPUTE_INTERVAL=5.0
INFERENCE_INTERVAL=5.0
MODEL_DIR=/app/shared/models
TRADING_PAIRS_FILE=/config/trading_pairs.txt
DB_PERSIST_INTERVAL=60

# ===========================================
# SERVICE URLS (Docker internal)
# ===========================================
FEATURE_STORE_URL=http://feature-store:8007
MARKET_DATA_URL=http://market-data:8001
PREDICTION_URL=http://prediction:8002
EXECUTOR_URL=http://executor:8005
POSITION_URL=http://position:8000
SIGNAL_URL=http://signal:8000
RISK_URL=http://risk:8000
API_GATEWAY_URL=http://api-gateway:8000

# ===========================================
# SENTIMENT & TREND COLLECTION
# ===========================================
CRYPTOPANIC_INTERVAL=300
REDDIT_INTERVAL=600
FEAR_GREED_INTERVAL=3600
GOOGLE_TRENDS_INTERVAL=14400
SOCIAL_VOLUME_INTERVAL=900
WHALE_TRACKER_INTERVAL=300
EXCHANGE_METRICS_INTERVAL=60
SENTIMENT_WINDOW_HOURS=24
FEATURE_TTL=10

# ===========================================
# PORTFOLIO OPTIMIZATION
# ===========================================
KELLY_MODE=half
CONFIDENCE_THRESHOLD=0.3
PORTFOLIO_CASH_RESERVE_PCT=0.20
PORTFOLIO_MAX_POSITION_PCT=0.05
